# ─── OpenTenders Configuration ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit your .env file to git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your-32-byte-hex-secret-here

# Session duration in days (default: 7)
AUTH_TTL_DAYS=7

# ── AI Enrichment (optional) ──────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
# If omitted, the app works fine — tenders won't have AI summaries or scores.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Scraper Settings ──────────────────────────────────────────────────────────
# Run browser in headless mode (set to false for debugging)
PLAYWRIGHT_HEADLESS=true

# Cron expression for auto-refresh (default: daily at 08:00)
REFRESH_CRON=0 8 * * *

# Request timeout per portal in milliseconds (default: 120000 = 2 minutes)
REQUEST_TIMEOUT_MS=120000

# Max characters of page text to pass to parser (default: 50000)
MAX_PAGE_TEXT_CHARS=50000
